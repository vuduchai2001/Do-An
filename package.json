{
  "name": "cli-proxy-monorepo",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "eslint apps/backend apps/web packages --ext .ts,.tsx,.js,.mjs",
    "format": "prettier --write \"apps/backend/**/*.{ts,mts,cts,js,mjs,json,yaml,yml,md}\" \"apps/web/**/*.{ts,tsx,js,mjs,json,yaml,yml,md,css}\" \"packages/**/*.{ts,tsx,js,mjs,json,yaml,yml,md}\" \"README.md\" \"AGENTS.md\" \"docs/**/*.md\"",
    "format:check": "prettier --check \"apps/backend/**/*.{ts,mts,cts,js,mjs,json,yaml,yml,md}\" \"apps/web/**/*.{ts,tsx,js,mjs,json,yaml,yml,md,css}\" \"packages/**/*.{ts,tsx,js,mjs,json,yaml,yml,md}\" \"README.md\" \"AGENTS.md\" \"docs/**/*.md\"",
    "dev:backend": "pnpm --filter @cliproxy/backend dev",
    "build:backend": "pnpm --filter @cliproxy/backend build",
    "typecheck:backend": "pnpm --filter @cliproxy/backend typecheck",
    "dev:web": "pnpm --filter @cliproxy/web dev",
    "build:web": "pnpm --filter @cliproxy/web build",
    "typecheck:web": "pnpm --filter @cliproxy/web typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2.5.6",
    "typescript-eslint": "^8.57.1"
  }
}
