{
  "name": "@cliproxy/backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "pnpm --dir ../.. exec eslint apps/backend/src apps/backend/test apps/backend/scripts --ext .ts,.mjs --config eslint.config.mjs",
    "format": "pnpm --dir ../.. exec prettier --write \"apps/backend/src/**/*.{ts,mts,cts}\" \"apps/backend/test/**/*.ts\" \"apps/backend/scripts/*.{mjs,js}\" \"apps/backend/*.{json,yaml,yml,md}\" --config prettier.config.mjs",
    "format:check": "pnpm --dir ../.. exec prettier --check \"apps/backend/src/**/*.{ts,mts,cts}\" \"apps/backend/test/**/*.ts\" \"apps/backend/scripts/*.{mjs,js}\" \"apps/backend/*.{json,yaml,yml,md}\" --config prettier.config.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "node scripts/migrate.mjs",
    "db:migrate:reset": "node scripts/reset-db.mjs"
  },
  "dependencies": {
    "fastify": "^5.6.1",
    "pg": "^8.20.0",
    "undici": "^7.16.0",
    "uuid": "^13.0.0",
    "yaml": "^2.8.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.17.0",
    "@types/pg": "^8.18.0",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2",
    "vitest": "^4.1.0"
  }
}
